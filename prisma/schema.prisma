// ============================================================================
// KUNSULT PLATFORM — SPRINT 1 PRODUCTION SCHEMA
//
// 8 engines. Full build: Commercial, Engagement, Assurance, Evidence.
// Foundation only (schema, no API/UI this sprint): Intelligence, Improvement
// is semi-built (Action CRUD included — see ENGINEERING_REVIEW.md for why),
// Report is semi-built, Knowledge is foundation-only.
//
// Conventions applied uniformly (see docs/DEVELOPER_HANDBOOK.md):
//   - UUID primary keys
//   - tenantId on every tenant-scoped model, indexed
//   - createdBy / updatedBy as plain string identifiers (see assumption A1
//     in docs/ENGINEERING_REVIEW.md — not enforced FKs to User)
//   - createdAt / updatedAt timestamps
//   - deletedAt for soft delete (null = active; no separate isDeleted flag,
//     to avoid two fields carrying the same fact — DRY)
//
// INTEGRATION NOTE: merge into your existing schema.prisma; do not replace.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// PLATFORM FOUNDATION
// ----------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users               User[]
  organisations       Organisation[]
  engagements         Engagement[]
  assessmentTemplates AssessmentTemplate[]

  @@index([slug])
}

// Minimal — enough to back createdBy/updatedBy display and role checks.
// Not a full auth system; wire to your existing auth provider (see README).
model User {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  name      String
  email     String   @unique
  role      String   @default("MEMBER") // ADMIN / LEAD_CONSULTANT / DELIVERY_PARTNER / ASSOCIATE / MEMBER

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

// ----------------------------------------------------------------------------
// PLATFORM FOUNDATION SERVICES — Audit, Notifications
//
// Every engine depends on these rather than logging or notifying
// independently. See lib/foundation/audit and lib/foundation/notifications.
// Permissions and search are code-level Foundation Services with no
// dedicated tables in Sprint 1 (see docs/ENGINEERING_REVIEW.md for the
// Sprint 2 case for a table-driven RBAC model). Storage is also code-level:
// engines still store the resulting URL on their own record (e.g.
// EvidenceItem.storageUrl) rather than a new FileAsset table, to avoid
// schema churn on engines already shipped this sprint.
// ----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String

  entityType String   // e.g. "Organisation", "Engagement"
  entityId   String
  action     String   // CREATE / UPDATE / SOFT_DELETE
  actorId    String?
  actorRole  String?

  before     Json?
  after      Json?

  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model Notification {
  id         String    @id @default(uuid())
  tenantId   String
  userId     String?   // null = unassigned/broadcast within tenant

  channel    String    @default("IN_APP") // IN_APP / EMAIL — foundation shell, no delivery provider wired yet
  eventType  String    // e.g. "ASSESSMENT_CRITICAL_OVERRIDE"
  title      String
  body       String

  entityType String?
  entityId   String?

  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, userId, readAt])
}

// ----------------------------------------------------------------------------
// SHARED ENUMS
// ----------------------------------------------------------------------------

enum PipelineStage {
  LEAD
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  COMPLETED
  TERMINATED
}

enum EngagementStatus {
  SCOPING
  MOBILISING
  ACTIVE
  QUALITY_REVIEW
  CLOSED
  CONTINUITY_PENDING
}

enum RatingLevel {
  CRITICAL
  RED
  AMBER
  GREEN
  NOT_APPLICABLE
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  MITIGATED
  CLOSED
}

enum EvidenceCategory {
  POLICY
  ROSTER
  INCIDENT_LOG
  CARE_PLAN
  INTERVIEW_NOTE
  REGULATORY_NOTICE
  AUDIT_WORKING_FILE
  OTHER
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETE
  OVERDUE
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportType {
  BOARD_REPORT
  MOCK_INSPECTION_REPORT
  REGULATION_17_REPORT
  IMPROVEMENT_PLAN
  EXECUTIVE_SUMMARY
  DUE_DILIGENCE_REPORT
}

enum ReportStatus {
  DRAFT
  GENERATED
  SIGNED_OFF
}

// ============================================================================
// 1. COMMERCIAL ENGINE
// ============================================================================

model Organisation {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  name         String
  sector       String?
  regulatoryId String?
  website      String?
  address      String?
  notes        String?

  createdBy    String?
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  contacts      Contact[]
  opportunities Opportunity[]
  quotes        Quote[]
  contracts     Contract[]
  engagements   Engagement[]

  @@index([tenantId])
}

model Contact {
  id             String       @id @default(uuid())
  tenantId       String
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean @default(false)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, organisationId])
}

model Opportunity {
  id             String        @id @default(uuid())
  tenantId       String
  organisationId String
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  title             String
  stage             PipelineStage @default(LEAD)
  estimatedValue    Decimal?      @db.Decimal(12, 2)
  source            String?
  regulatoryUrgency Boolean       @default(false)
  closeDate         DateTime?

  quotes    Quote[]
  proposals Proposal[]

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, organisationId, stage])
}

model Quote {
  id             String       @id @default(uuid())
  tenantId       String
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  opportunityId  String?
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id])

  summary    String
  totalValue Decimal     @db.Decimal(12, 2)
  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, organisationId])
}

model Proposal {
  id            String      @id @default(uuid())
  tenantId      String
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  version           Int       @default(1)
  scopeSummary      String
  price             Decimal   @db.Decimal(12, 2)
  statutoryDeadline DateTime?
  sentAt            DateTime?
  acceptedAt        DateTime?

  contract Contract?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, opportunityId])
}

model Contract {
  id             String       @id @default(uuid())
  tenantId       String
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  proposalId     String?      @unique
  proposal       Proposal?    @relation(fields: [proposalId], references: [id])

  status    ContractStatus @default(DRAFT)
  value     Decimal        @db.Decimal(12, 2)
  startDate DateTime?
  endDate   DateTime?

  engagement Engagement?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, organisationId])
}

// ============================================================================
// 2. ENGAGEMENT ENGINE (platform core)
// ============================================================================

model Engagement {
  id             String           @id @default(uuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  organisationId String
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  contractId     String?          @unique
  contract       Contract?        @relation(fields: [contractId], references: [id])

  name          String
  status        EngagementStatus @default(SCOPING)
  scopeSummary  String?
  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?

  team          EngagementMember[]
  milestones    Milestone[]
  products      EngagementProduct[]
  risks         Risk[]
  evidenceItems EvidenceItem[]
  assessments   Assessment[]
  findings      Finding[]
  actions       Action[]
  reports       Report[]

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, organisationId, status])
}

model EngagementMember {
  id           String     @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  name           String
  role           String
  isClientFacing Boolean @default(false)

  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@index([tenantId, engagementId])
}

model Milestone {
  id           String     @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  label       String
  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@index([tenantId, engagementId])
}

// Product Apps are configurations of engines, not new engine logic — this
// join table is where a Product App's identity and config attach to a real
// engagement without any product-specific tables.
model EngagementProduct {
  id           String     @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  productCode String
  productName String
  configJson  Json?

  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@index([tenantId, engagementId])
}

model Risk {
  id           String     @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  title       String
  description String?
  likelihood  RiskSeverity
  impact      RiskSeverity
  mitigation  String?
  ownerName   String?
  status      RiskStatus   @default(OPEN)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, engagementId, status])
}

// ============================================================================
// 3. ASSURANCE ENGINE (configurable — templates only, no assessment-specific code)
// ============================================================================

model AssessmentTemplate {
  id       String  @id @default(uuid())
  tenantId String? // null = platform-wide template available to all tenants
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  name        String
  version     String  @default("1.0")
  description String?
  isActive    Boolean @default(true)

  questions   AssessmentQuestion[]
  assessments Assessment[]

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

model AssessmentQuestion {
  id         String             @id @default(uuid())
  templateId String
  template   AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  domain           String // e.g. "Safe", "Well-led" — configurable, never hardcoded
  standardRef      String? // e.g. a CQC KLOE reference — configurable
  prompt           String
  evidenceRequired Boolean @default(true)
  weight           Int     @default(1)
  sortOrder        Int     @default(0)

  answers AssessmentAnswer[]

  deletedAt DateTime?

  @@index([templateId])
}

model Assessment {
  id           String             @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement         @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  templateId   String
  template     AssessmentTemplate @relation(fields: [templateId], references: [id])

  status           String       @default("IN_PROGRESS") // IN_PROGRESS / COMPLETE — action language, not RAG
  overallRating    RatingLevel?
  criticalOverride Boolean      @default(false)

  answers  AssessmentAnswer[]
  findings Finding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, engagementId])
}

model AssessmentAnswer {
  id           String     @id @default(uuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   String
  question     AssessmentQuestion @relation(fields: [questionId], references: [id])

  rating RatingLevel
  notes  String?

  evidenceLinks EvidenceItem[] @relation("AnswerEvidence")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assessmentId])
  @@index([questionId])
}

model Finding {
  id           String      @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement  @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id])

  title       String
  description String
  rating      RatingLevel
  domain      String?

  recommendations Recommendation[]
  actions         Action[]

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, engagementId])
}

model Recommendation {
  id        String  @id @default(uuid())
  findingId String
  finding   Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  text     String
  priority String @default("MEDIUM")

  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@index([findingId])
}

// ============================================================================
// 4. EVIDENCE ENGINE
// ============================================================================

model EvidenceItem {
  id           String           @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  title      String
  category   EvidenceCategory
  tags       String[]         @default([])
  storageUrl String
  mimeType   String?

  answerLinks AssessmentAnswer[] @relation("AnswerEvidence")
  versions    EvidenceVersion[]

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, engagementId, category])
}

// Versions are append-only and never soft-deleted — they are the audit
// trail for evidence integrity. See docs/DEVELOPER_HANDBOOK.md.
model EvidenceVersion {
  id             String       @id @default(uuid())
  evidenceItemId String
  evidenceItem   EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)

  versionNumber Int
  storageUrl    String
  changeNote    String?
  uploadedBy    String?

  createdAt DateTime @default(now())

  @@index([evidenceItemId])
}

// ============================================================================
// 5. INTELLIGENCE ENGINE — FOUNDATION ONLY (no logic, no API this sprint)
// ============================================================================

model RiskSignal {
  id             String  @id @default(uuid())
  tenantId       String
  engagementId   String?
  organisationId String?

  signalType  String // free-text pattern type, e.g. "recurring-red-domain"
  description String
  sourceEngine String // which engine raised it, e.g. "Assurance"
  detectedAt  DateTime @default(now())

  @@index([tenantId])
}

model ExecutiveSummary {
  id           String @id @default(uuid())
  tenantId     String
  engagementId String

  generatedFor String // "Board", "Client", "Internal"
  summaryText  String
  generatedAt  DateTime @default(now())

  @@index([tenantId, engagementId])
}

model BenchmarkMetric {
  id       String @id @default(uuid())
  tenantId String?

  metricName  String
  metricValue Decimal  @db.Decimal(12, 4)
  cohort      String? // e.g. "domiciliary-care-uk"
  periodStart DateTime
  periodEnd   DateTime

  @@index([tenantId, metricName])
}

// ============================================================================
// 6. IMPROVEMENT ENGINE
// ============================================================================

model Action {
  id           String       @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement   @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  findingId    String?
  finding      Finding?     @relation(fields: [findingId], references: [id])

  title       String
  ownerName   String?
  priority    ActionPriority @default(MEDIUM)
  status      ActionStatus   @default(OPEN)
  dueDate     DateTime?
  completedAt DateTime?

  progressNotes ActionProgressNote[]
  evidenceOfCompletionUrl String?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, engagementId, status])
}

model ActionProgressNote {
  id       String @id @default(uuid())
  actionId String
  action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

  note             String
  percentComplete  Int
  recordedBy       String?
  recordedAt       DateTime @default(now())

  @@index([actionId])
}

// ============================================================================
// 7. REPORT ENGINE
// ============================================================================

model Report {
  id           String     @id @default(uuid())
  tenantId     String
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  title       String
  reportType  ReportType
  status      ReportStatus @default(DRAFT)
  storageUrl  String?
  signedOffBy String?
  signedOffAt DateTime?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, engagementId, reportType])
}

// ============================================================================
// 8. KNOWLEDGE ENGINE — FOUNDATION ONLY (no logic, no API this sprint)
// ============================================================================

model BestPractice {
  id       String  @id @default(uuid())
  tenantId String? // null = platform-wide

  title               String
  description         String
  domain              String?
  sourceEngagementId  String?

  createdAt DateTime @default(now())

  @@index([tenantId, domain])
}

model LessonLearned {
  id           String  @id @default(uuid())
  tenantId     String
  engagementId String?

  title       String
  description String
  category    String?

  createdAt DateTime @default(now())

  @@index([tenantId])
}

// Platform-level, not tenant-scoped — deliberately cross-tenant so
// benchmarking has a meaningful comparison pool. Governance for what may
// be aggregated across tenants is a policy decision, not a schema one —
// flagged in docs/ENGINEERING_REVIEW.md.
model BenchmarkDataset {
  id          String @id @default(uuid())
  name        String
  description String?
  dataJson    Json

  createdAt DateTime @default(now())
}

model ReusableRecommendationTemplate {
  id       String  @id @default(uuid())
  tenantId String? // null = platform-wide

  domain    String
  text      String
  timesUsed Int    @default(0)

  createdAt DateTime @default(now())

  @@index([tenantId, domain])
}
